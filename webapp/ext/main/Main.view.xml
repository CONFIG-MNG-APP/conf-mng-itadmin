<mvc:View
    controllerName="zgsp26.conf.mng.itadmin.ext.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:FlexibleColumnLayout id="fcl" layout="{fcl>/layout}"
                            backgroundDesign="Solid"
                            class="itadmin-fcl">

        <!-- ═══════════════════════════════════════════
             BEGIN COLUMN — Master (My Inbox left panel)
        ════════════════════════════════════════════════ -->
        <f:beginColumnPages>
            <Page id="masterPage"
                  showHeader="false"
                  enableScrolling="true"
                  class="itadmin-master-page">
                <content>

                    <!-- ① Sticky Master Header ─────────────────── -->
                    <HBox justifyContent="SpaceBetween" alignItems="Center"
                          class="itadmin-master-hdr">
                        <VBox justifyContent="Center">
                            <Title text="Config Requests" level="H4"
                                   class="itadmin-master-title"/>
                            <HBox alignItems="Center" class="itadmin-kpi-row">
                                <ObjectStatus text="{kpi>/atDev} DEV"
                                              state="Warning"
                                              class="sapUiTinyMarginEnd"
                                              visible="{= ${kpi>/atDev} > 0}"/>
                                <ObjectStatus text="{kpi>/atQas} QAS"
                                              state="Information"
                                              class="sapUiTinyMarginEnd"
                                              visible="{= ${kpi>/atQas} > 0}"/>
                                <ObjectStatus text="{kpi>/atPrd} PRD"
                                              state="Success"
                                              class="sapUiTinyMarginEnd"
                                              visible="{= ${kpi>/atPrd} > 0}"/>
                                <Text text="{= ${kpi>/total} + ' requests'}"
                                      class="itadmin-kpi-total"
                                      visible="{= ${kpi>/total} > 0}"/>
                            </HBox>
                        </VBox>
                        <HBox alignItems="Center">
                            <Button icon="sap-icon://compare"
                                    type="Transparent"
                                    tooltip="So sánh môi trường"
                                    press=".onEnvCompareOpen"/>
                            <Button id="notifBell"
                                    icon="sap-icon://bell"
                                    type="Transparent"
                                    tooltip="Thông báo"
                                    press=".onNotifBellPress">
                                <customData>
                                    <BadgeCustomData key="badge"
                                        value="{notif>/count}"
                                        visible="{= ${notif>/count} > 0}"/>
                                </customData>
                            </Button>
                        </HBox>
                    </HBox>

                    <!-- ② Module Tabs ───────────────────────────── -->
                    <IconTabBar id="moduleTabBar"
                                expandable="false"
                                stretchContentHeight="false"
                                select=".onTabSelect"
                                selectedKey="MM"
                                class="itadmin-module-tabs">
                        <items>
                            <IconTabFilter key="MM"    text="MM Route"
                                count="{= '' + ${kpi>/mmCount}}"
                                icon="sap-icon://shipping-status"/>
                            <IconTabFilter key="MMSS"  text="Safe Stock"
                                count="{= '' + ${kpi>/mmssCount}}"
                                icon="sap-icon://inventory"/>
                            <IconTabFilter key="FI"    text="FI Limit"
                                count="{= '' + ${kpi>/fiCount}}"
                                icon="sap-icon://money-bills"/>
                            <IconTabFilter key="SD"    text="SD Price"
                                count="{= '' + ${kpi>/sdCount}}"
                                icon="sap-icon://sales-quote"/>
                        </items>
                        <content/>
                    </IconTabBar>

                    <!-- ③ Filter Strip — Requests ───────────────── -->
                    <VBox class="itadmin-filter-strip">
                        <SearchField id="searchField"
                                     placeholder="Tìm theo tên, người tạo, key..."
                                     search=".onSearch"
                                     showSearchButton="false"/>
                        <HBox alignItems="Center" wrap="Wrap"
                              class="itadmin-filter-row">
                            <SegmentedButton id="envSegment"
                                             selectedKey=""
                                             selectionChange=".onFilter"
                                             class="itadmin-env-seg">
                                <items>
                                    <SegmentedButtonItem key=""    text="Tất cả"/>
                                    <SegmentedButtonItem key="DEV" text="DEV"/>
                                    <SegmentedButtonItem key="QAS" text="QAS"/>
                                    <SegmentedButtonItem key="PRD" text="PRD"/>
                                </items>
                            </SegmentedButton>
                            <ToolbarSpacer/>
                            <DateRangeSelection id="dateFilter"
                                                width="11.5rem"
                                                change=".onFilter"
                                                placeholder="Từ — đến"/>
                            <Button icon="sap-icon://clear-filter"
                                    type="Transparent"
                                    tooltip="Xóa bộ lọc"
                                    press=".onClearFilter"
                                    class="sapUiTinyMarginBegin"/>
                            <Button icon="sap-icon://refresh"
                                    type="Transparent"
                                    tooltip="Refresh"
                                    press=".onRefresh"/>
                        </HBox>
                    </VBox>

                    <!-- ④ Request List ──────────────────────────── -->
                    <List id="requestList"
                          noDataText="Không có request nào."
                          items="{vm>/requests}"
                          selectionChange=".onRequestListSelect"
                          mode="SingleSelectMaster"
                          growing="true" growingThreshold="30"
                          showSeparators="Inner"
                          class="itadmin-inbox-list">
                        <items>
                            <CustomListItem class="itadmin-inbox-item">
                                <VBox class="itadmin-item-body">
                                    <!-- Row 1: Title + ENV badge -->
                                    <HBox justifyContent="SpaceBetween"
                                          alignItems="Start">
                                        <Text text="{= ${vm>ReqTitle} || '(Không có tên)'}"
                                              class="itadmin-item-title"
                                              wrapping="true" width="78%"/>
                                        <ObjectStatus
                                            text="{vm>EnvId}"
                                            state="{= ${vm>EnvId} === 'PRD' ? 'Success' :
                                                       ${vm>EnvId} === 'QAS' ? 'Warning' : 'Information'}"
                                            inverted="true"
                                            class="itadmin-item-env"/>
                                    </HBox>
                                    <!-- Row 2: Module pill + by + date + status -->
                                    <HBox justifyContent="SpaceBetween"
                                          alignItems="Center"
                                          class="itadmin-item-meta">
                                        <HBox alignItems="Center">
                                            <ObjectStatus
                                                text="{vm>ModuleId}"
                                                state="{= ${vm>ModuleId} === 'FI' ? 'Information' :
                                                           ${vm>ModuleId} === 'SD' ? 'Success' : 'Warning'}"
                                                inverted="true"
                                                class="itadmin-mod-pill"/>
                                            <core:Icon src="sap-icon://employee"
                                                       color="#C5CAD0" size="0.7rem"
                                                       class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
                                            <Text text="{vm>CreatedBy}"
                                                  class="itadmin-meta-txt"/>
                                            <Text text=" · " class="itadmin-meta-txt"/>
                                            <Text text="{vm>_createdAtFmt}"
                                                  class="itadmin-meta-txt"/>
                                        </HBox>
                                        <ObjectStatus
                                            text="{= ${vm>Status} === 'ACTIVE' ? 'Active' : 'Approved'}"
                                            state="{= ${vm>Status} === 'ACTIVE' ? 'Success' : 'Warning'}"
                                            class="itadmin-item-status"/>
                                    </HBox>
                                    <!-- Row 3: Key info -->
                                    <Text text="{vm>_keyInfo}"
                                          class="itadmin-item-key"
                                          wrapping="false"/>
                                </VBox>
                            </CustomListItem>
                        </items>
                    </List>

                </content>
            </Page>
        </f:beginColumnPages>

        <!-- ═══════════════════════════════════════════
             MID COLUMN — Detail (My Inbox right panel)
        ════════════════════════════════════════════════ -->
        <f:midColumnPages>
            <Page id="detailPage"
                  showHeader="false"
                  enableScrolling="true"
                  class="itadmin-detail-page">
                <content>

                    <!-- ═══ DEFAULT VIEW: Audit Trail (always shown unless a request is open) ═══ -->
                    <VBox visible="{detail>/isAuditDefault}" class="itadmin-audit-panel">

                        <!-- Audit header -->
                        <HBox alignItems="Center" justifyContent="SpaceBetween"
                              class="itadmin-detail-hdr">
                            <VBox class="itadmin-detail-hdr-content">
                                <Title text="Audit Trail" level="H4"
                                       class="itadmin-detail-title"/>
                            </VBox>
                            <Button icon="sap-icon://refresh"
                                    type="Transparent"
                                    tooltip="Refresh"
                                    press=".onAuditRefresh"/>
                        </HBox>

                        <!-- Audit filter strip -->
                        <VBox class="itadmin-filter-strip">
                            <SearchField id="auditSearch"
                                         placeholder="Tìm audit log..."
                                         search=".onAuditSearch"
                                         showSearchButton="false"/>
                            <HBox alignItems="Center" wrap="Wrap"
                                  class="itadmin-filter-row">
                                <Select id="auditModuleFilter" width="7rem"
                                        selectedKey="" change=".onAuditFilter">
                                    <items>
                                        <core:Item key="" text="Module"/>
                                        <core:Item key="MM"   text="MM"/>
                                        <core:Item key="MMSS" text="MMSS"/>
                                        <core:Item key="FI"   text="FI"/>
                                        <core:Item key="SD"   text="SD"/>
                                    </items>
                                </Select>
                                <Select id="auditEnvFilter" width="5.5rem"
                                        selectedKey="" change=".onAuditFilter"
                                        class="sapUiTinyMarginBegin">
                                    <items>
                                        <core:Item key="" text="ENV"/>
                                        <core:Item key="DEV" text="DEV"/>
                                        <core:Item key="QAS" text="QAS"/>
                                        <core:Item key="PRD" text="PRD"/>
                                    </items>
                                </Select>
                                <Select id="auditActionFilter" width="7.5rem"
                                        selectedKey="" change=".onAuditFilter"
                                        class="sapUiTinyMarginBegin">
                                    <items>
                                        <core:Item key="" text="Action"/>
                                        <core:Item key="APPROVE"  text="Approve"/>
                                        <core:Item key="PROMOTE"  text="Promote"/>
                                        <core:Item key="ROLLBACK" text="Rollback"/>
                                    </items>
                                </Select>
                                <ToolbarSpacer/>
                                <Button icon="sap-icon://clear-filter"
                                        type="Transparent"
                                        press=".onAuditClearFilter"/>
                            </HBox>
                        </VBox>

                        <!-- Audit list -->
                        <List id="auditList"
                              noDataText="Không có dữ liệu audit."
                              items="{vm>/auditDisplay}"
                              selectionChange=".onAuditListSelect"
                              mode="SingleSelectMaster"
                              growing="true" growingThreshold="50"
                              showSeparators="Inner"
                              class="itadmin-audit-list">
                            <items>
                                <CustomListItem class="itadmin-inbox-item">
                                    <VBox class="itadmin-item-body">
                                        <HBox justifyContent="SpaceBetween"
                                              alignItems="Start">
                                            <Text text="{vm>reqTitle}"
                                                  class="itadmin-item-title"
                                                  wrapping="true" width="78%"/>
                                            <ObjectStatus
                                                text="{vm>envId}"
                                                state="{= ${vm>envId} === 'PRD' ? 'Success' :
                                                           ${vm>envId} === 'QAS' ? 'Warning' : 'Information'}"
                                                inverted="true"
                                                class="itadmin-item-env"/>
                                        </HBox>
                                        <HBox justifyContent="SpaceBetween"
                                              alignItems="Center"
                                              class="itadmin-item-meta">
                                            <HBox alignItems="Center">
                                                <ObjectStatus
                                                    text="{vm>actionType}"
                                                    state="{= ${vm>actionType} === 'ROLLBACK' ? 'Error' :
                                                               ${vm>actionType} === 'PROMOTE'  ? 'Warning' : 'Success'}"
                                                    inverted="true"
                                                    class="itadmin-mod-pill"/>
                                                <Text text="{vm>tableName}"
                                                      class="itadmin-meta-txt sapUiTinyMarginBegin"/>
                                            </HBox>
                                            <HBox alignItems="Center">
                                                <core:Icon src="sap-icon://employee"
                                                           color="#C5CAD0" size="0.7rem"
                                                           class="sapUiTinyMarginEnd"/>
                                                <Text text="{vm>changedBy}"
                                                      class="itadmin-meta-txt"/>
                                                <Text text=" · " class="itadmin-meta-txt"/>
                                                <Text text="{vm>changedAt}"
                                                      class="itadmin-meta-txt"/>
                                            </HBox>
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </items>
                        </List>

                    </VBox>
                    <!-- ═══════════════════════════════════════════════════════════ -->

                    <!-- ① Sticky Detail Header ──────────────────── -->
                    <HBox alignItems="Center" class="itadmin-detail-hdr"
                          visible="{= !${detail>/isAuditDefault}}">
                        <Button icon="sap-icon://nav-back"
                                type="Transparent"
                                press=".onDetailBack"
                                class="itadmin-back-btn"/>
                        <VBox class="itadmin-detail-hdr-content">
                            <Title text="{= ${detail>/confName} || 'Chi tiết Request'}"
                                   level="H4" class="itadmin-detail-title"
                                   wrapping="false"/>
                            <HBox alignItems="Center" class="itadmin-detail-subtitle">
                                <ObjectStatus
                                    text="{detail>/module}"
                                    state="{= ${detail>/module} === 'FI' ? 'Information' :
                                               ${detail>/module} === 'SD' ? 'Success' : 'Warning'}"
                                    inverted="true"
                                    class="sapUiTinyMarginEnd"/>
                                <ObjectStatus
                                    text="{detail>/curEnv}"
                                    state="{= ${detail>/curEnv} === 'PRD' ? 'Success' :
                                               ${detail>/curEnv} === 'QAS' ? 'Warning' : 'Information'}"
                                    inverted="true"
                                    class="sapUiTinyMarginEnd"/>
                                <Text text="{= ${detail>/by} ? 'by ' + ${detail>/by} : ''}"
                                      class="itadmin-meta-txt"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ② Tab strip: Journey | Preview | Info ────── -->
                    <IconTabBar id="detailTabBar"
                                select=".onDetailTabSelect"
                                expandable="false"
                                stretchContentHeight="false"
                                visible="{= !${detail>/isAuditDefault}}"
                                class="itadmin-detail-tabs">
                        <items>

                            <!-- Tab 1: Preview Changes — admin xem WHAT changed trước tiên -->
                            <IconTabFilter key="PREVIEW"
                                           icon="sap-icon://detail-view"
                                           text="Preview">
                                <content>
                                    <VBox class="itadmin-tab-content">
                                        <Toolbar style="Clear" height="2.25rem"
                                                 class="itadmin-preview-bar">
                                            <ToolbarSpacer/>
                                            <ToggleButton
                                                text="Chỉ hiện thay đổi"
                                                icon="sap-icon://filter"
                                                pressed="{detail>/showChangedOnly}"
                                                press=".onToggleChangedOnly"/>
                                        </Toolbar>
                                        <VBox id="previewTableContainer"/>
                                    </VBox>
                                </content>
                            </IconTabFilter>

                            <!-- Tab 2: Journey — xem WHERE + promote/rollback actions -->
                            <IconTabFilter key="JOURNEY"
                                           icon="sap-icon://journey-arrive"
                                           text="Journey">
                                <content>
                                    <VBox class="itadmin-tab-content">
                                        <!-- Rollback confirm -->
                                        <Panel visible="{detail>/showRollbackConfirm}"
                                               class="itadmin-rollback-panel">
                                            <headerToolbar>
                                                <Toolbar style="Clear" height="2.5rem">
                                                    <core:Icon src="sap-icon://warning2"
                                                               color="#E9730C" size="0.9rem"
                                                               class="sapUiTinyMarginEnd"/>
                                                    <Title text="{= 'Xác nhận Rollback — ' + ${detail>/rollbackTargetEnv}}"
                                                           level="H5"/>
                                                    <ToolbarSpacer/>
                                                    <Button icon="sap-icon://decline"
                                                            type="Transparent"
                                                            press=".onRollbackCancel"/>
                                                </Toolbar>
                                            </headerToolbar>
                                            <VBox class="sapUiSmallMargin">
                                                <MessageStrip
                                                    text="{= 'Dữ liệu tại ' + ${detail>/rollbackTargetEnv} + ' sẽ revert về giá trị cũ. Hành động không thể hoàn tác!'}"
                                                    type="Warning" showIcon="true"
                                                    class="sapUiTinyMarginBottom"/>
                                                <HBox class="sapUiSmallMarginTop">
                                                    <Button text="Xác nhận Rollback"
                                                            type="Reject"
                                                            icon="sap-icon://undo"
                                                            press=".onRollbackConfirm"/>
                                                    <Button text="Hủy"
                                                            press=".onRollbackCancel"
                                                            class="sapUiSmallMarginBegin"/>
                                                </HBox>
                                            </VBox>
                                        </Panel>
                                        <!-- Journey timeline (rendered by controller) -->
                                        <HBox id="journeyContainer"
                                              alignItems="Center"
                                              justifyContent="Center"
                                              class="itadmin-journey-box"/>
                                    </VBox>
                                </content>
                            </IconTabFilter>

                            <!-- Tab 3: Info — metadata (least urgent) -->
                            <IconTabFilter key="INFO"
                                           icon="sap-icon://hint"
                                           text="Info">
                                <content>
                                    <VBox class="itadmin-tab-content itadmin-info-tab">
                                        <HBox wrap="Wrap" alignItems="Start"
                                              class="itadmin-info-fields">
                                            <VBox class="itadmin-info-field">
                                                <Label text="Module" design="Bold"/>
                                                <ObjectStatus text="{detail>/module}"
                                                    state="{= ${detail>/module} === 'FI' ? 'Information' :
                                                               ${detail>/module} === 'SD' ? 'Success' : 'Warning'}"
                                                    inverted="true"/>
                                            </VBox>
                                            <VBox class="itadmin-info-field">
                                                <Label text="ENV hiện tại" design="Bold"/>
                                                <ObjectStatus text="{detail>/curEnv}"
                                                    state="{= ${detail>/curEnv} === 'PRD' ? 'Success' :
                                                               ${detail>/curEnv} === 'QAS' ? 'Warning' : 'Information'}"
                                                    inverted="true"/>
                                            </VBox>
                                            <VBox class="itadmin-info-field">
                                                <Label text="Requested By" design="Bold"/>
                                                <HBox alignItems="Center">
                                                    <core:Icon src="sap-icon://employee"
                                                               color="#89919A" size="0.85rem"
                                                               class="sapUiTinyMarginEnd"/>
                                                    <Text text="{detail>/by}"/>
                                                </HBox>
                                            </VBox>
                                            <VBox class="itadmin-info-field">
                                                <Label text="Request ID" design="Bold"/>
                                                <Text text="{detail>/reqId}"
                                                      class="sapUiSmallText sapThemeNeutralText"/>
                                            </VBox>
                                            <VBox width="100%" class="itadmin-info-field">
                                                <Label text="Reason" design="Bold"/>
                                                <Text text="{= ${detail>/reason} &amp;&amp; ${detail>/reason} !== '-' ? ${detail>/reason} : '(không có lý do)'}"
                                                      wrapping="true"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </content>
                            </IconTabFilter>

                        </items>
                    </IconTabBar>

                </content>

                <!-- Footer: action buttons (hidden when showing Audit Trail default) -->
                <footer>
                    <OverflowToolbar class="itadmin-action-footer"
                                     visible="{= !${detail>/isAuditDefault}}">
                        <Button id="detailPromoteBtn"
                                text="{= 'Promote → ' + ${detail>/nextEnv}}"
                                icon="sap-icon://journey-arrive"
                                type="Accept"
                                visible="{detail>/isPromoteMode}"
                                enabled="{detail>/promoteEnabled}"
                                press=".onDialogPromote"/>
                        <Button text="Rollback"
                                icon="sap-icon://undo"
                                type="Reject"
                                visible="{= !${detail>/isPromoteMode} &amp;&amp; ${detail>/curEnv} !== 'DEV'}"
                                press=".onQuickRollbackPress"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://compare"
                                type="Transparent"
                                tooltip="So sánh môi trường"
                                press=".onEnvCompareOpen"/>
                        <Button text="Đóng"
                                type="Transparent"
                                icon="sap-icon://decline"
                                press=".onDetailBack"/>
                    </OverflowToolbar>
                </footer>

            </Page>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>

</mvc:View>
