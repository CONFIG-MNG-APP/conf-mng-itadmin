<mvc:View
    controllerName="zgsp26.conf.mng.itadmin.ext.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:FlexibleColumnLayout id="fcl" layout="{fcl>/layout}"
                            backgroundDesign="Solid"
                            class="itadmin-fcl">

        <!-- ═══════════════════════════════════════════
             BEGIN COLUMN — Master (My Inbox left panel)
        ════════════════════════════════════════════════ -->
        <f:beginColumnPages>
            <Page id="masterPage"
                  showHeader="false"
                  enableScrolling="true"
                  class="itadmin-master-page">
                <content>

                    <!-- ① Sticky Master Header -->
                    <VBox class="itadmin-master-hdr">
                        <!-- Row 1: Title + Actions -->
                        <HBox alignItems="Center" justifyContent="SpaceBetween">
                            <!-- Left: title + KPI -->
                            <VBox justifyContent="Center" class="itadmin-hdr-left">
                                <Title text="IT Admin Console" level="H4"
                                       class="itadmin-master-title"/>
                                <HBox alignItems="Center" class="itadmin-kpi-row">
                                    <ObjectStatus text="{kpi>/atDev} DEV"
                                                  state="Warning"
                                                  class="sapUiTinyMarginEnd"
                                                  visible="{= ${kpi>/atDev} > 0}"/>
                                    <ObjectStatus text="{kpi>/atQas} QAS"
                                                  state="Information"
                                                  class="sapUiTinyMarginEnd"
                                                  visible="{= ${kpi>/atQas} > 0}"/>
                                    <ObjectStatus text="{kpi>/atPrd} PRD"
                                                  state="Success"
                                                  class="sapUiTinyMarginEnd"
                                                  visible="{= ${kpi>/atPrd} > 0}"/>
                                    <Text text="{= ${kpi>/total} + ' requests'}"
                                          class="itadmin-kpi-total"
                                          visible="{= ${kpi>/total} > 0}"/>
                                </HBox>
                            </VBox>

                            <!-- Right: action buttons -->
                            <HBox alignItems="Center" justifyContent="End" class="itadmin-hdr-right">
                                <HBox id="notifBellWrapper"
                                      alignItems="Center"
                                      class="itNotifBellWrapper">
                                    <Button id="notifBell"
                                            icon="sap-icon://bell"
                                            type="Transparent"
                                            tooltip="Notifications"
                                            press=".onNotifBellPress"/>
                                    <Text id="notifBadgeText"
                                          text="{= ${notif>/unreadCount} > 99 ? '99+' : String(${notif>/unreadCount})}"
                                          visible="{= ${notif>/unreadCount} > 0}"
                                          class="itNotifBadge"/>
                                </HBox>
                            </HBox>
                        </HBox>

                        <!-- Row 2: Section Navigation -->
                        <HBox justifyContent="Center" alignItems="Center" class="sapUiSmallMarginTop">
                            <SegmentedButton id="sectionSwitch"
                                             selectedKey="{= ${vm>/userMgmtMode} ? 'USERS' : 'REQUESTS'}"
                                             selectionChange=".onSectionSwitch">
                                <items>
                                    <SegmentedButtonItem key="REQUESTS" text="Requests" width="8rem"/>
                                    <SegmentedButtonItem key="USERS"    text="User Management" width="10rem"/>
                                </items>
                            </SegmentedButton>
                        </HBox>
                    </VBox>

                    <!-- ③ Module Tabs ───────────────────────────── -->
                    <IconTabBar id="moduleTabBar"
                                visible="{= !${vm>/userMgmtMode}}"
                                expandable="false"
                                stretchContentHeight="false"
                                select=".onTabSelect"
                                selectedKey="MM"
                                class="itadmin-module-tabs">
                        <items>
                            <IconTabFilter key="MM"    text="MM Route"
                                count="{= '' + ${kpi>/mmCount}}"
                                icon="sap-icon://shipping-status"/>
                            <IconTabFilter key="MMSS"  text="Safe Stock"
                                count="{= '' + ${kpi>/mmssCount}}"
                                icon="sap-icon://inventory"/>
                            <IconTabFilter key="FI"    text="FI Limit"
                                count="{= '' + ${kpi>/fiCount}}"
                                icon="sap-icon://money-bills"/>
                            <IconTabFilter key="SD"    text="SD Price"
                                count="{= '' + ${kpi>/sdCount}}"
                                icon="sap-icon://sales-quote"/>
                        </items>
                        <content/>
                    </IconTabBar>

                    <!-- ④ Filter Strip — Requests ───────────────── -->
                    <VBox class="itadmin-filter-strip" visible="{= !${vm>/userMgmtMode}}">
                        <SearchField id="searchField"
                                     placeholder="Search by name, creator, key..."
                                     search=".onSearch"
                                     showSearchButton="false"/>
                        <HBox alignItems="Center" wrap="Wrap"
                              class="itadmin-filter-row">
                            <SegmentedButton id="envSegment"
                                             selectedKey=""
                                             selectionChange=".onFilter"
                                             class="itadmin-env-seg">
                                <items>
                                    <SegmentedButtonItem key=""    text="All"/>
                                    <SegmentedButtonItem key="DEV" text="DEV"/>
                                    <SegmentedButtonItem key="QAS" text="QAS"/>
                                    <SegmentedButtonItem key="PRD" text="PRD"/>
                                </items>
                            </SegmentedButton>
                            <ToolbarSpacer/>
                            <DateRangeSelection id="dateFilter"
                                                width="11.5rem"
                                                change=".onFilter"
                                                placeholder="From — To"/>
                            <Button icon="sap-icon://clear-filter"
                                    type="Transparent"
                                    tooltip="Clear Filters"
                                    press=".onClearFilter"
                                    class="sapUiTinyMarginBegin"/>
                            <Button icon="sap-icon://refresh"
                                    type="Transparent"
                                    tooltip="Refresh"
                                    press=".onRefresh"/>
                        </HBox>
                    </VBox>

                    <!-- ⑤ Request List ──────────────────────────── -->
                    <List id="requestList"
                          visible="{= !${vm>/userMgmtMode}}"
                          noDataText="No requests found."
                          items="{vm>/requests}"
                          selectionChange=".onRequestListSelect"
                          mode="SingleSelectMaster"
                          growing="true" growingThreshold="30"
                          showSeparators="Inner"
                          class="itadmin-inbox-list">
                        <items>
                            <CustomListItem class="itadmin-inbox-item">
                                <VBox class="itadmin-item-body">
                                    <!-- Row 1: Title + ENV badge -->
                                    <HBox justifyContent="SpaceBetween"
                                          alignItems="Start">
                                        <Text text="{= ${vm>ReqTitle} || '(No name)'}"
                                              class="itadmin-item-title"
                                              wrapping="true" width="78%"/>
                                        <ObjectStatus
                                            text="{vm>EnvId}"
                                            state="{= ${vm>EnvId} === 'PRD' ? 'Success' :
                                                       ${vm>EnvId} === 'QAS' ? 'Warning' : 'Information'}"
                                            inverted="true"
                                            class="itadmin-item-env"/>
                                    </HBox>
                                    <!-- Row 2: Module pill + by + date + status -->
                                    <HBox justifyContent="SpaceBetween"
                                          alignItems="Center"
                                          class="itadmin-item-meta">
                                        <HBox alignItems="Center">
                                            <ObjectStatus
                                                text="{vm>ModuleId}"
                                                state="{= ${vm>ModuleId} === 'FI' ? 'Information' :
                                                           ${vm>ModuleId} === 'SD' ? 'Success' : 'Warning'}"
                                                inverted="true"
                                                class="itadmin-mod-pill"/>
                                            <core:Icon src="sap-icon://employee"
                                                       color="#C5CAD0" size="0.7rem"
                                                       class="sapUiTinyMarginBegin sapUiTinyMarginEnd"/>
                                            <Text text="{vm>CreatedBy}"
                                                  class="itadmin-meta-txt"/>
                                            <Text text=" · " class="itadmin-meta-txt"/>
                                            <Text text="{vm>_createdAtFmt}"
                                                  class="itadmin-meta-txt"/>
                                        </HBox>
                                        <ObjectStatus
                                            text="{= ${vm>Status} === 'ACTIVE' ? 'Active' : 'Approved'}"
                                            state="{= ${vm>Status} === 'ACTIVE' ? 'Success' : 'Warning'}"
                                            class="itadmin-item-status"/>
                                    </HBox>
                                    <!-- Row 3: Key info -->
                                    <Text text="{vm>_keyInfo}"
                                          class="itadmin-item-key"
                                          wrapping="false"/>
                                </VBox>
                            </CustomListItem>
                        </items>
                    </List>

                    <!-- ⑥ User Management Panel — grouped user list ─── -->
                    <VBox visible="{vm>/userMgmtMode}">
                        <!-- Search + Refresh + Add User toolbar -->
                        <Toolbar class="itadmin-usermgmt-toolbar">
                            <SearchField id="userSearchField"
                                         placeholder="Search user ID or name..."
                                         search=".onUserSearch"
                                         showSearchButton="false"/>
                            <ToolbarSpacer/>
                            <Button icon="sap-icon://refresh" type="Transparent"
                                    tooltip="Refresh" press=".onUserMgmtRefresh"/>
                            <Button text="Add User" icon="sap-icon://add-employee"
                                    type="Emphasized" press=".onAddUser"/>
                        </Toolbar>
                        <!-- Filter strip: Module + Role -->
                        <HBox class="itadmin-usermgmt-filter" alignItems="Center">
                            <Label text="Module" class="sapUiTinyMarginEnd"/>
                            <Select id="umFilterModule"
                                    width="7rem"
                                    change=".onUserFilterChange"
                                    class="sapUiTinyMarginEnd">
                                <items>
                                    <core:Item key="" text="All"/>
                                    <core:Item key="FI"   text="FI"/>
                                    <core:Item key="MM"   text="MM"/>
                                    <core:Item key="MMSS" text="MMSS"/>
                                    <core:Item key="SD"   text="SD"/>
                                    <core:Item key="ALL"  text="ALL"/>
                                </items>
                            </Select>
                            <Label text="Role" class="sapUiTinyMarginEnd"/>
                            <Select id="umFilterRole"
                                    width="8.5rem"
                                    change=".onUserFilterChange"
                                    class="sapUiTinyMarginEnd">
                                <items>
                                    <core:Item key=""          text="All"/>
                                    <core:Item key="KEY USER"  text="Key User"/>
                                    <core:Item key="MANAGER"   text="Manager"/>
                                    <core:Item key="IT ADMIN"  text="IT Admin"/>
                                </items>
                            </Select>
                            <Button icon="sap-icon://clear-filter"
                                    type="Transparent"
                                    tooltip="Clear filters"
                                    press=".onUserFilterClear"
                                    visible="{= !!(${vm>/umFilter/module} || ${vm>/umFilter/role})}"/>
                        </HBox>
                        <!-- User list (grouped by UserId) -->
                        <List id="userList"
                              noDataText="No users found."
                              items="{vm>/users}"
                              selectionChange=".onUserListSelect"
                              mode="SingleSelectMaster"
                              growing="true" growingThreshold="50"
                              showSeparators="Inner"
                              class="itadmin-inbox-list">
                            <items>
                                <CustomListItem class="itadmin-inbox-item">
                                    <VBox class="itadmin-item-body">
                                        <!-- Row 1: User ID + Active badge -->
                                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                                            <HBox alignItems="Center">
                                                <core:Icon src="sap-icon://employee"
                                                           color="#0070F2" size="0.875rem"
                                                           class="sapUiTinyMarginEnd"/>
                                                <Text text="{vm>userId}"
                                                      class="itadmin-item-title"/>
                                            </HBox>
                                            <ObjectStatus
                                                text="{= ${vm>isActive} ? 'Active' : 'Inactive'}"
                                                state="{= ${vm>isActive} ? 'Success' : 'Error'}"
                                                class="itadmin-item-env"/>
                                        </HBox>
                                        <!-- Row 2: Fullname -->
                                        <Text text="{vm>fullname}"
                                              class="itadmin-meta-txt"
                                              visible="{= !!${vm>fullname}}"/>
                                        <!-- Row 3: Role pills + module pills -->
                                        <HBox alignItems="Center" wrap="Wrap"
                                              class="itadmin-item-meta sapUiTinyMarginTop">
                                            <ObjectStatus
                                                text="{vm>primaryRole}"
                                                state="{= ${vm>primaryRole} === 'IT ADMIN' ? 'Success' :
                                                           ${vm>primaryRole} === 'MANAGER'  ? 'Warning' : 'Information'}"
                                                inverted="true"
                                                class="itadmin-mod-pill sapUiTinyMarginEnd"/>
                                            <Text text="{vm>modulesSummary}"
                                                  class="itadmin-item-key"/>
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </items>
                        </List>
                    </VBox>

                </content>
            </Page>
        </f:beginColumnPages>

        <!-- ═══════════════════════════════════════════
             MID COLUMN — Detail (My Inbox right panel)
        ════════════════════════════════════════════════ -->
        <f:midColumnPages>
            <Page id="detailPage"
                  showHeader="false"
                  enableScrolling="true"
                  class="itadmin-detail-page">
                <content>

                    <!-- ═══ DEFAULT VIEW: Audit Trail (always shown unless a request is open) ═══ -->
                    <VBox visible="{= ${detail>/isAuditDefault} &amp;&amp; !${vm>/userDetailMode}}" class="itadmin-audit-panel">

                        <!-- Audit header -->
                        <HBox alignItems="Center" justifyContent="SpaceBetween"
                              class="itadmin-detail-hdr">
                            <VBox class="itadmin-detail-hdr-content">
                                <Title text="Audit Trail" level="H4"
                                       class="itadmin-detail-title"/>
                            </VBox>
                            <Button icon="sap-icon://refresh"
                                    type="Transparent"
                                    tooltip="Refresh"
                                    press=".onAuditRefresh"/>
                        </HBox>

                        <!-- Audit filter strip -->
                        <VBox class="itadmin-filter-strip">
                            <SearchField id="auditSearch"
                                         placeholder="Search audit log..."
                                         search=".onAuditSearch"
                                         showSearchButton="false"/>
                            <HBox alignItems="Center" wrap="Wrap"
                                  class="itadmin-filter-row">
                                <Select id="auditModuleFilter" width="7rem"
                                        selectedKey="" change=".onAuditFilter">
                                    <items>
                                        <core:Item key="" text="Module"/>
                                        <core:Item key="MM"   text="MM"/>
                                        <core:Item key="MMSS" text="MMSS"/>
                                        <core:Item key="FI"   text="FI"/>
                                        <core:Item key="SD"   text="SD"/>
                                    </items>
                                </Select>
                                <Select id="auditEnvFilter" width="5.5rem"
                                        selectedKey="" change=".onAuditFilter"
                                        class="sapUiTinyMarginBegin">
                                    <items>
                                        <core:Item key="" text="ENV"/>
                                        <core:Item key="DEV" text="DEV"/>
                                        <core:Item key="QAS" text="QAS"/>
                                        <core:Item key="PRD" text="PRD"/>
                                    </items>
                                </Select>
                                <Select id="auditActionFilter" width="7.5rem"
                                        selectedKey="" change=".onAuditFilter"
                                        class="sapUiTinyMarginBegin">
                                    <items>
                                        <core:Item key="" text="Action"/>
                                        <core:Item key="APPROVE"  text="Approve"/>
                                        <core:Item key="PROMOTE"  text="Promote"/>
                                        <core:Item key="ROLLBACK" text="Rollback"/>
                                    </items>
                                </Select>
                                <ToolbarSpacer/>
                                <Button icon="sap-icon://clear-filter"
                                        type="Transparent"
                                        press=".onAuditClearFilter"/>
                            </HBox>
                        </VBox>

                        <!-- Audit list -->
                        <List id="auditList"
                              noDataText="No audit data."
                              items="{vm>/auditDisplay}"
                              selectionChange=".onAuditListSelect"
                              mode="SingleSelectMaster"
                              growing="true" growingThreshold="50"
                              showSeparators="Inner"
                              class="itadmin-audit-list">
                            <items>
                                <CustomListItem class="itadmin-inbox-item">
                                    <VBox class="itadmin-item-body">
                                        <HBox justifyContent="SpaceBetween"
                                              alignItems="Start">
                                            <Text text="{vm>reqTitle}"
                                                  class="itadmin-item-title"
                                                  wrapping="true" width="78%"/>
                                            <ObjectStatus
                                                text="{vm>envId}"
                                                state="{= ${vm>envId} === 'PRD' ? 'Success' :
                                                           ${vm>envId} === 'QAS' ? 'Warning' : 'Information'}"
                                                inverted="true"
                                                class="itadmin-item-env"/>
                                        </HBox>
                                        <HBox justifyContent="SpaceBetween"
                                              alignItems="Center"
                                              class="itadmin-item-meta">
                                            <HBox alignItems="Center">
                                                <ObjectStatus
                                                    text="{vm>actionType}"
                                                    state="{= ${vm>actionType} === 'ROLLBACK' ? 'Error' :
                                                               ${vm>actionType} === 'PROMOTE'  ? 'Warning' : 'Success'}"
                                                    inverted="true"
                                                    class="itadmin-mod-pill"/>
                                                <ObjectStatus
                                                    text="{vm>moduleId}"
                                                    state="{= ${vm>moduleId} === 'FI' ? 'Warning' :
                                                               ${vm>moduleId} === 'SD' ? 'Success' : 'Information'}"
                                                    inverted="true"
                                                    class="itadmin-mod-pill sapUiTinyMarginBegin"/>
                                                <Text text="{= ${vm>rowCount} + ' record' + (${vm>rowCount} > 1 ? 's' : '')}"
                                                      class="itadmin-meta-txt sapUiTinyMarginBegin"/>
                                            </HBox>
                                            <HBox alignItems="Center">
                                                <core:Icon src="sap-icon://employee"
                                                           color="#C5CAD0" size="0.7rem"
                                                           class="sapUiTinyMarginEnd"/>
                                                <Text text="{vm>changedBy}"
                                                      class="itadmin-meta-txt"/>
                                                <Text text=" · " class="itadmin-meta-txt"/>
                                                <Text text="{vm>changedAt}"
                                                      class="itadmin-meta-txt"/>
                                            </HBox>
                                        </HBox>
                                    </VBox>
                                </CustomListItem>
                            </items>
                        </List>

                    </VBox>
                    <!-- ═══ USER DETAIL PANEL (shown when a user is selected in User Management) ═══ -->
                    <VBox visible="{vm>/userDetailMode}" class="itadmin-user-detail-panel">

                        <!-- User Detail Header -->
                        <HBox alignItems="Center" justifyContent="SpaceBetween"
                              class="itadmin-detail-hdr">
                            <HBox alignItems="Center">
                                <Button icon="sap-icon://nav-back"
                                        type="Transparent"
                                        press=".onUserDetailBack"
                                        class="itadmin-back-btn"/>
                                <VBox class="itadmin-detail-hdr-content">
                                    <Title text="{vm>/selectedUser/userId}"
                                           level="H4" class="itadmin-detail-title"/>
                                    <HBox alignItems="Center" class="itadmin-detail-subtitle">
                                        <Text text="{vm>/selectedUser/fullname}"
                                              class="itadmin-meta-txt"
                                              visible="{= !!${vm>/selectedUser/fullname}}"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                            <Button text="Deactivate All"
                                    icon="sap-icon://locked"
                                    type="Reject"
                                    visible="{vm>/selectedUser/isActive}"
                                    press=".onDeactivateAllRoles"/>
                        </HBox>

                        <!-- Roles Section -->
                        <VBox class="itadmin-user-section">
                            <HBox justifyContent="SpaceBetween" alignItems="Center"
                                  class="itadmin-user-section-hdr">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://role" color="#0070F2"
                                               size="0.875rem" class="sapUiTinyMarginEnd"/>
                                    <Title text="Roles" level="H5"/>
                                </HBox>
                                <Button text="Add" icon="sap-icon://add"
                                        type="Emphasized" press=".onAddRole"/>
                            </HBox>
                            <List id="userRoleList"
                                  noDataText="No roles assigned."
                                  items="{vm>/selectedUser/roles}"
                                  showSeparators="Inner"
                                  class="itadmin-user-detail-list">
                                <items>
                                    <CustomListItem class="itadmin-user-role-item">
                                        <HBox justifyContent="SpaceBetween" alignItems="Center"
                                              class="itadmin-user-role-row">
                                            <HBox alignItems="Center" wrap="Wrap">
                                                <ObjectStatus text="{vm>ModuleId}"
                                                    state="Information" inverted="true"
                                                    class="itadmin-mod-pill sapUiSmallMarginEnd"/>
                                                <ObjectStatus text="{vm>RoleLevel}"
                                                    state="{= ${vm>RoleLevel} === 'IT ADMIN' ? 'Success' :
                                                               ${vm>RoleLevel} === 'MANAGER'  ? 'Warning' : 'Information'}"
                                                    inverted="true"
                                                    class="itadmin-mod-pill"/>
                                                <Text text="{= 'Org: ' + ${vm>OrgAccess}}"
                                                      visible="{= !!(${vm>OrgAccess} &amp;&amp; ${vm>OrgAccess} !== '*')}"
                                                      class="itadmin-item-key sapUiTinyMarginBegin"/>
                                            </HBox>
                                            <HBox alignItems="Center">
                                                <Switch state="{vm>IsActive}"
                                                        customTextOn="On" customTextOff="Off"
                                                        change=".onToggleRoleActive"/>
                                                <Button icon="sap-icon://delete"
                                                        type="Transparent"
                                                        press=".onDeleteRole"
                                                        class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                        </HBox>
                                    </CustomListItem>
                                </items>
                            </List>
                        </VBox>

                        <!-- Emails Section -->
                        <VBox class="itadmin-user-section">
                            <HBox justifyContent="SpaceBetween" alignItems="Center"
                                  class="itadmin-user-section-hdr">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://email" color="#0070F2"
                                               size="0.875rem" class="sapUiTinyMarginEnd"/>
                                    <Title text="Emails" level="H5"/>
                                </HBox>
                                <Button text="Add" icon="sap-icon://add"
                                        type="Emphasized" press=".onAddMail"/>
                            </HBox>
                            <List id="userMailList"
                                  noDataText="No emails assigned."
                                  items="{vm>/selectedUser/mails}"
                                  showSeparators="Inner"
                                  class="itadmin-user-detail-list">
                                <items>
                                    <CustomListItem class="itadmin-user-role-item">
                                        <HBox justifyContent="SpaceBetween" alignItems="Center"
                                              class="itadmin-user-role-row">
                                            <HBox alignItems="Center">
                                                <core:Icon src="sap-icon://email"
                                                           color="#89919A" size="0.8rem"
                                                           class="sapUiTinyMarginEnd"/>
                                                <Text text="{vm>Email}" class="itadmin-meta-txt"/>
                                            </HBox>
                                            <HBox alignItems="Center">
                                                <Button icon="sap-icon://edit"
                                                        type="Transparent"
                                                        tooltip="Edit email"
                                                        press=".onEditMail"/>
                                                <Button icon="sap-icon://delete"
                                                        type="Transparent"
                                                        press=".onDeleteMail"/>
                                            </HBox>
                                        </HBox>
                                    </CustomListItem>
                                </items>
                            </List>
                        </VBox>

                    </VBox>
                    <!-- ═══════════════════════════════════════════════════════════ -->

                    <!-- ① Sticky Detail Header ──────────────────── -->
                    <HBox alignItems="Center" class="itadmin-detail-hdr"
                          visible="{= !${detail>/isAuditDefault} &amp;&amp; !${vm>/userDetailMode}}">
                        <Button icon="sap-icon://nav-back"
                                type="Transparent"
                                press=".onDetailBack"
                                class="itadmin-back-btn"/>
                        <VBox class="itadmin-detail-hdr-content">
                            <Title text="{= ${detail>/confName} || 'Request Details'}"
                                   level="H4" class="itadmin-detail-title"
                                   wrapping="false"/>
                            <HBox alignItems="Center" class="itadmin-detail-subtitle">
                                <ObjectStatus
                                    text="{detail>/module}"
                                    state="{= ${detail>/module} === 'FI' ? 'Information' :
                                               ${detail>/module} === 'SD' ? 'Success' : 'Warning'}"
                                    inverted="true"
                                    class="sapUiTinyMarginEnd"/>
                                <ObjectStatus
                                    text="{detail>/curEnv}"
                                    state="{= ${detail>/curEnv} === 'PRD' ? 'Success' :
                                               ${detail>/curEnv} === 'QAS' ? 'Warning' : 'Information'}"
                                    inverted="true"
                                    class="sapUiTinyMarginEnd"/>
                                <Text text="{= ${detail>/by} ? 'by ' + ${detail>/by} : ''}"
                                      class="itadmin-meta-txt"/>
                            </HBox>
                            <HBox alignItems="Start" class="sapUiTinyMarginTop"
                                  visible="{= !!(${detail>/reason} &amp;&amp; ${detail>/reason} !== '-')}">
                                <core:Icon src="sap-icon://hint"
                                           color="#0a6ed1" size="0.8rem"
                                           class="sapUiTinyMarginEnd itadmin-reason-icon"/>
                                <Text text="{detail>/reason}"
                                      wrapping="true"
                                      class="itadmin-reason-text"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ② Tab strip: Journey | Preview | Info ────── -->
                    <IconTabBar id="detailTabBar"
                                select=".onDetailTabSelect"
                                expandable="false"
                                stretchContentHeight="false"
                                visible="{= !${detail>/isAuditDefault} &amp;&amp; !${vm>/userDetailMode}}"
                                class="itadmin-detail-tabs">
                        <items>

                            <!-- Tab 1: Preview Changes — admin xem WHAT changed trước tiên -->
                            <IconTabFilter key="PREVIEW"
                                           icon="sap-icon://detail-view"
                                           text="Preview">
                                <content>
                                    <VBox class="itadmin-tab-content">
                                        <VBox id="previewTableContainer"/>
                                    </VBox>
                                </content>
                            </IconTabFilter>

                            <!-- Tab 2: Journey — xem WHERE + promote/rollback actions -->
                            <IconTabFilter key="JOURNEY"
                                           icon="sap-icon://journey-arrive"
                                           text="Journey">
                                <content>
                                    <VBox class="itadmin-tab-content">
                                        <!-- Journey timeline (rendered by controller) -->
                                        <HBox id="journeyContainer"
                                              alignItems="Center"
                                              justifyContent="Center"
                                              class="itadmin-journey-box"/>
                                    </VBox>
                                </content>
                            </IconTabFilter>

                        </items>
                    </IconTabBar>

                </content>

                <!-- Footer: action buttons (hidden when showing Audit Trail default) -->
                <footer>
                    <OverflowToolbar class="itadmin-action-footer"
                                     visible="{= !${detail>/isAuditDefault} &amp;&amp; !${vm>/userDetailMode}}">
                        <Button id="detailPromoteBtn"
                                text="{= 'Promote → ' + ${detail>/nextEnv}}"
                                icon="sap-icon://journey-arrive"
                                type="Accept"
                                visible="{detail>/isPromoteMode}"
                                enabled="{detail>/promoteEnabled}"
                                press=".onDialogPromote"/>
                        <Button text="Rollback"
                                icon="sap-icon://undo"
                                type="Reject"
                                visible="{= !${detail>/isPromoteMode} &amp;&amp; ${detail>/curEnv} !== 'DEV'}"
                                press=".onQuickRollbackPress"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://compare"
                                type="Transparent"
                                tooltip="Compare Environments"
                                press=".onEnvCompareOpen"/>
                        <Button text="Close"
                                type="Transparent"
                                icon="sap-icon://decline"
                                press=".onDetailBack"/>
                    </OverflowToolbar>
                </footer>

            </Page>
        </f:midColumnPages>

    </f:FlexibleColumnLayout>

</mvc:View>
