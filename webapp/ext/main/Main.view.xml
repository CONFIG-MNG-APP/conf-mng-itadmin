<mvc:View
    controllerName="zgsp26.conf.mng.itadmin.ext.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page id="mainPage" title="IT Admin — Configuration Management" showHeader="true">
        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Filter Bar -->
                <HBox wrap="Wrap" alignItems="End" class="sapUiTinyMarginBottom sapUiSmallMarginTop">

                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Module"/>
                        <Select id="moduleFilter" width="10rem" selectedKey="" change=".onFilter">
                            <items>
                                <core:Item key=""   text="All Modules"/>
                                <core:Item key="MM" text="MM"/>
                                <core:Item key="FI" text="FI"/>
                                <core:Item key="SD" text="SD"/>
                            </items>
                        </Select>
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="ENV"/>
                        <Select id="envFilter" width="9rem" selectedKey="" change=".onFilter">
                            <items>
                                <core:Item key=""    text="All"/>
                                <core:Item key="DEV" text="DEV"/>
                                <core:Item key="QAS" text="QAS"/>
                                <core:Item key="PRD" text="PRD"/>
                            </items>
                        </Select>
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Date Range"/>
                        <DateRangeSelection id="dateFilter" width="16rem" change=".onFilter"/>
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Search"/>
                        <SearchField id="searchField" width="14rem" search=".onSearch"/>
                    </VBox>

                    <VBox justifyContent="End">
                        <Label text="&#160;"/>
                        <Button text="Clear" press=".onClearFilter"/>
                    </VBox>

                    <ToolbarSpacer/>

                    <VBox justifyContent="End">
                        <Label text="&#160;"/>
                        <Button text="Refresh" icon="sap-icon://refresh" press=".onRefresh"/>
                    </VBox>

                </HBox>

                <!-- Request Table -->
                <Table id="requestTable" mode="None" growing="true"
                       growingScrollToLoad="true" inset="false"
                       items="{
                           path: '/ZC_CONF_REQ_H',
                           filters: [{path: 'Status', operator: 'EQ', value1: 'APPROVED'}]
                       }">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Danh sách Request đã Approved" level="H3"/>
                            <ToolbarSpacer/>
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="14rem"><Text text="REQ_ID"/></Column>
                        <Column width="7rem"><Text text="Module"/></Column>
                        <Column><Text text="Config"/></Column>
                        <Column width="10rem"><Text text="Status"/></Column>
                        <Column width="12rem"><Text text="By"/></Column>
                        <Column width="9rem" hAlign="Center"><Text text="Action"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{ReqId}"/>
                                <Text text="{ModuleId}"/>
                                <Text text="{ReqTitle}"/>
                                <ObjectStatus
                                    text="{= ${Status} === 'APPROVED' || ${Status} === 'A' ? 'Approved' :
                                              ${Status} === 'ACTIVE'      ? 'Applied'    :
                                              ${Status} === 'ROLLED_BACK' ? 'Rolled Back' : ${Status}}"
                                    state="{= ${Status} === 'APPROVED' || ${Status} === 'A' ? 'Warning' :
                                               ${Status} === 'ACTIVE'      ? 'Success'  :
                                               ${Status} === 'ROLLED_BACK' ? 'Error'    : 'None'}"/>
                                <Text text="{CreatedBy}"/>
                                <Button
                                    text="{= ${Status} === 'APPROVED' || ${Status} === 'A' ? 'Apply' :
                                              (${Status} === 'ACTIVE' &amp;&amp; ${EnvId} !== 'PRD') ? 'Promote' : 'View'}"
                                    type="{= ${Status} === 'APPROVED' || ${Status} === 'A' ? 'Emphasized' :
                                               (${Status} === 'ACTIVE' &amp;&amp; ${EnvId} !== 'PRD') ? 'Accept' : 'Default'}"
                                    icon="{= (${Status} === 'ACTIVE' &amp;&amp; ${EnvId} !== 'PRD') ? 'sap-icon://journey-arrive' : ''}"
                                    press=".onActionPress"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>
        </content>
    </Page>
</mvc:View>
