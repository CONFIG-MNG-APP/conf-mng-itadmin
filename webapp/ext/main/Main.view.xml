<mvc:View
    controllerName="zgsp26.conf.mng.itadmin.ext.main.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page id="mainPage" title="IT Admin — Configuration Request Management">
        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Filter Bar -->
                <Panel expandable="true" expanded="true" headerText="Filter"
                       class="sapUiTinyMarginBottom sapUiContentPadding">
                    <HBox wrap="Wrap" class="sapUiTinyMarginTop">

                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Status"/>
                            <Select id="statusFilter" width="12rem" selectedKey="APPROVED" change=".onFilter">
                                <items>
                                    <core:Item key=""         text="All"/>
                                    <core:Item key="APPROVED" text="Approved"/>
                                    <core:Item key="ACTIVE"   text="Active"/>
                                </items>
                            </Select>
                        </VBox>

                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Module"/>
                            <Select id="moduleFilter" width="12rem" selectedKey="" change=".onFilter">
                                <items>
                                    <core:Item key=""   text="All Modules"/>
                                    <core:Item key="MM" text="MM"/>
                                    <core:Item key="FI" text="FI"/>
                                    <core:Item key="SD" text="SD"/>
                                </items>
                            </Select>
                        </VBox>

                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Current Env"/>
                            <Select id="envFilter" width="10rem" selectedKey="" change=".onFilter">
                                <items>
                                    <core:Item key=""    text="All"/>
                                    <core:Item key="DEV" text="DEV"/>
                                    <core:Item key="QAS" text="QAS"/>
                                    <core:Item key="PRD" text="PRD"/>
                                </items>
                            </Select>
                        </VBox>

                        <VBox class="sapUiSmallMarginEnd" justifyContent="End">
                            <Label text="&#160;"/>
                            <Button text="Clear" press=".onClearFilter"/>
                        </VBox>

                    </HBox>
                </Panel>

                <!-- Toolbar -->
                <OverflowToolbar class="sapUiTinyMarginBottom">
                    <Title text="Promote &amp; Rollback Dashboard" level="H2"/>
                    <ToolbarSpacer/>
                    <Button text="Promote to Next Env"
                            icon="sap-icon://accept"
                            type="Emphasized"
                            press=".onPromote"/>
                    <Button text="Rollback"
                            icon="sap-icon://undo"
                            type="Reject"
                            press=".onRollback"/>
                    <Button text="Refresh"
                            icon="sap-icon://refresh"
                            press=".onRefresh"/>
                </OverflowToolbar>

                <!-- Request Table -->
                <Table id="requestTable" mode="MultiSelect" growing="true"
                       growingScrollToLoad="true" inset="false"
                       items="{
                           path: '/ZC_CONF_REQ_H',
                           filters: [{path: 'Status', operator: 'EQ', value1: 'APPROVED'}]
                       }">

                    <columns>
                        <Column width="14rem"><Text text="Request ID"/></Column>
                        <Column><Text text="Title"/></Column>
                        <Column width="7rem"><Text text="Module"/></Column>
                        <Column width="9rem"><Text text="Current Env"/></Column>
                        <Column width="9rem"><Text text="Next Env"/></Column>
                        <Column width="10rem"><Text text="Status"/></Column>
                        <Column width="12rem"><Text text="Approved By"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem type="Navigation" press=".onRowPress">
                            <cells>
                                <Text text="{ReqId}"/>
                                <Text text="{ReqTitle}"/>
                                <Text text="{ModuleId}"/>
                                <ObjectStatus
                                    text="{EnvId}"
                                    state="{= ${EnvId} === 'PRD' ? 'Error' :
                                              ${EnvId} === 'QAS' ? 'Warning' : 'Success'}"/>
                                <ObjectStatus
                                    text="{= ${EnvId} === 'DEV' ? 'QAS' :
                                              ${EnvId} === 'QAS' ? 'PRD' : '—'}"
                                    state="{= ${EnvId} === 'QAS' ? 'Error' :
                                              ${EnvId} === 'DEV' ? 'Warning' : 'None'}"/>
                                <ObjectStatus
                                    text="{= ${Status} === 'APPROVED'     ? 'Approved' :
                                              ${Status} === 'A'           ? 'Approved' :
                                              ${Status} === 'ACTIVE'      ? 'Active'   :
                                              ${Status} === 'ROLLED_BACK' ? 'Rolled Back' : ${Status}}"
                                    state="{= ${Status} === 'APPROVED'     ? 'Warning' :
                                               ${Status} === 'A'           ? 'Warning' :
                                               ${Status} === 'ACTIVE'      ? 'Success' :
                                               ${Status} === 'ROLLED_BACK' ? 'Error'   : 'None'}"/>
                                <Text text="{ApprovedBy}"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>
        </content>
    </Page>
</mvc:View>
