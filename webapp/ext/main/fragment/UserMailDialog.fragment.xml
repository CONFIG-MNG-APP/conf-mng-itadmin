<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout.form">

    <Dialog title="{mailDialog>/title}" contentWidth="26rem" resizable="true">
        <content>
            <l:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="4" labelSpanL="4" labelSpanM="4"
                emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                class="sapUiSmallMargin">

                <l:content>
                    <Label text="User ID" required="true"/>
                    <Input value="{mailDialog>/UserId}"
                           enabled="{mailDialog>/isNew}"
                           placeholder="e.g. JDOE"
                           maxLength="12"/>

                    <Label text="Email" required="true"/>
                    <Input value="{mailDialog>/Email}"
                           placeholder="e.g. user@company.com"
                           type="Email"
                           maxLength="100"/>
                </l:content>
            </l:SimpleForm>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press=".onSaveMail"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onMailDialogClose"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>
