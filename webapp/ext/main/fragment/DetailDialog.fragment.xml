<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">

    <Dialog id="detailDialog"
            title="{= ${detail>/isApplyMode} ? 'Apply Configuration — REQ_ID: ' + ${detail>/reqId} :
                       ${detail>/isPromoteMode} ? 'Promote Configuration — REQ_ID: ' + ${detail>/reqId} :
                       'View Configuration — REQ_ID: ' + ${detail>/reqId} }"
            contentWidth="60rem" contentHeight="44rem"
            verticalScrolling="false" draggable="true" resizable="true">

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Request Info -->
                <Panel headerText="Request Info" expandable="false" class="sapUiTinyMarginBottom">
                    <HBox wrap="Wrap" class="sapUiSmallMargin" alignItems="Start">
                        <VBox class="sapUiSmallMarginEnd" width="14rem">
                            <Label text="Module" design="Bold"/>
                            <Text text="{detail>/module}"/>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd" width="18rem">
                            <Label text="Config" design="Bold"/>
                            <Text text="{detail>/confName}"/>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd" width="10rem">
                            <Label text="By" design="Bold"/>
                            <Text text="{detail>/by}"/>
                        </VBox>
                        <VBox width="auto">
                            <Label text="Reason" design="Bold"/>
                            <Text text="{detail>/reason}" wrapping="true" width="16rem"/>
                        </VBox>
                    </HBox>
                </Panel>

                <!-- Preview thay đổi -->
                <Panel headerText="Preview thay đổi" expandable="false" class="sapUiTinyMarginBottom">
                    <Table id="previewTable" inset="false"
                           noDataText="Loading..."
                           items="{detail>/lines}">
                        <columns>
                            <Column width="10rem"><Text text="Field"/></Column>
                            <Column><Text text="Giá trị cũ"/></Column>
                            <Column><Text text="Giá trị mới"/></Column>
                            <Column width="9rem" hAlign="Center"><Text text="Thay đổi"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{detail>field}"/>
                                    <Text text="{detail>oldVal}"/>
                                    <Text text="{detail>newVal}"/>
                                    <HBox alignItems="Center" justifyContent="Center">
                                        <core:Icon
                                            src="sap-icon://arrow-left"
                                            color="{= ${detail>changed} ? '#BB0000' : 'Default'}"
                                            visible="{detail>changed}"
                                            size="0.75rem"
                                            class="sapUiTinyMarginEnd"/>
                                        <Text
                                            text="{= ${detail>changed} ? 'changed' : 'no change'}"
                                            class="{= ${detail>changed} ? 'sapThemeNegativeText' : ''}"/>
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <!-- Editable table (IT Admin có thể sửa trước khi Apply) -->
                <Panel id="editablePanel"
                       headerText="IT Admin có thể sửa trực tiếp trước khi Apply"
                       expandable="true" expanded="true"
                       visible="{= ${detail>/isApplyMode} &amp;&amp; !${detail>/isPromoteMode}}"
                       class="sapUiTinyMarginBottom">
                    <VBox>
                        <MessageStrip
                            text="Chỉ hiển thị các dòng có thay đổi. Bạn có thể chỉnh sửa giá trị mới trước khi Apply."
                            type="Information" showIcon="true" showCloseButton="false"
                            class="sapUiTinyMarginBottom sapUiTinyMargin"/>
                        <Table id="editableTable" inset="false"
                               noDataText="Không có thay đổi nào."
                               items="{detail>/editableLines}">
                            <columns>
                                <Column width="10rem"><Text text="Field"/></Column>
                                <Column><Text text="Giá trị cũ"/></Column>
                                <Column><Text text="Giá trị mới (có thể sửa)"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{detail>field}"/>
                                        <Text text="{detail>oldVal}"/>
                                        <Input value="{detail>newVal}" width="100%"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </Panel>

            </VBox>
        </content>

        <buttons>
            <!-- Apply: lưu data vào bảng chính qua PATCH -->
            <Button id="dlgApplyBtn"
                    text="Apply"
                    icon="sap-icon://save"
                    type="Emphasized"
                    visible="{detail>/isApplyMode}"
                    press=".onDialogApply"/>
            <!-- Promote: chuyển môi trường lên tầng cao hơn -->
            <Button id="dlgPromoteBtn"
                    text="{= ${detail>/nextEnv} !== '—' ? 'Promote ' : 'Promote'}"
                    icon="sap-icon://journey-arrive"
                    type="Accept"
                    visible="{= ${detail>/isApplyMode} || ${detail>/isPromoteMode}}"
                    press=".onDialogPromote"/>
            <Button text="{= ${detail>/isApplyMode} ? 'Cancel' : 'Close'}"
                    press=".onDialogClose"/>
        </buttons>

    </Dialog>

</core:FragmentDefinition>
